# Groq — multi-key rotation (up to 5 keys × 100K TPD = 500K tokens/day).
# Create free accounts at console.groq.com and paste keys below.
# Falls back to GROQ_API_KEY if numbered keys are absent.
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...
GROQ_API_KEY_4=gsk_...
GROQ_API_KEY_5=gsk_...
GROQ_API_KEY=gsk_...   # legacy / single-key fallback

# Circle (leave blank to run in demo mode — Circle payments only, LLM is always real)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
PLATFORM_WALLET_ID=
CIRCLE_USDC_TOKEN_ID=

# Arc Testnet
ARC_CHAIN_ID=1111
ARC_RPC_URL=https://arc-node.thecanteenapp.com

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000
ORCHESTRATOR_URL=http://localhost:4000
