# Groq — primary LLM provider (fast, free). Get key at console.groq.com
GROQ_API_KEY=gsk_...

# OpenRouter — fallback when Groq rate-limits. Free models: qwen/qwen3-coder:free, meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_API_KEY=sk-or-v1-...

# Circle (leave blank to run in demo mode)
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
PLATFORM_WALLET_ID=
CIRCLE_USDC_TOKEN_ID=

# Arc Testnet
ARC_CHAIN_ID=1111
ARC_RPC_URL=https://arc-node.thecanteenapp.com

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000
ORCHESTRATOR_URL=http://localhost:4000
