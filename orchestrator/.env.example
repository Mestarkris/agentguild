# AgentGuild Orchestrator Environment Variables

PORT=4000
NODE_ENV=development

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Circle / Arc
CIRCLE_API_KEY=your_circle_api_key_here
CIRCLE_ENTITY_SECRET=your_entity_secret_here
CIRCLE_WALLET_SET_ID=your_wallet_set_id_here
ARC_RPC_URL=https://arc-node.thecanteenapp.com
ARC_CHAIN_ID=1111

# Escrow wallet (platform-controlled, funds agent payouts)
PLATFORM_WALLET_ID=your_platform_wallet_id
PLATFORM_WALLET_ADDRESS=your_platform_wallet_address
CIRCLE_USDC_TOKEN_ID=your_usdc_token_id

# Agent endpoints (all running locally in dev)
AGENT_SUMMARIZER_URL=http://localhost:4001
AGENT_CODE_REVIEW_URL=http://localhost:4002
AGENT_RESEARCH_URL=http://localhost:4003
AGENT_TRANSLATE_URL=http://localhost:4004
AGENT_SENTIMENT_URL=http://localhost:4005
AGENT_SQL_URL=http://localhost:4006
AGENT_CHART_URL=http://localhost:4007
AGENT_EXTRACT_URL=http://localhost:4008
AGENT_LEGAL_REVIEW_URL=http://localhost:4009
AGENT_FINANCE_URL=http://localhost:4010
AGENT_TRANSCRIBE_URL=http://localhost:4011
AGENT_FACT_CHECK_URL=http://localhost:4012

# Frontend
FRONTEND_URL=http://localhost:3000
